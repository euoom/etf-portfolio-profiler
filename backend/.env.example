# Comma-separated frontend origins allowed to call this API.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://euoom.github.io

# Hosted NVIDIA NIM / NVIDIA API Catalog settings.
# Keep real values only in backend/.env or server environment variables.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=

# Optional non-NVIDIA LLM provider credentials for future API-backed providers.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional local CLI provider settings for POC use.
LLM_PROVIDER=nvidia
LOCAL_LLM_COMMAND=
