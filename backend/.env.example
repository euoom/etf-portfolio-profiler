# Comma-separated frontend origins allowed to call this API.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://euoom.github.io

# Optional LLM provider credentials for future API-backed providers.
# Keep real values only in backend/.env or server environment variables.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional local CLI provider settings for POC use.
LLM_PROVIDER=mock
LOCAL_LLM_COMMAND=
