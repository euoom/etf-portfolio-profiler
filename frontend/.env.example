# Public API base URL used by the browser app.
# This value is bundled into frontend JavaScript and must not contain secrets.
VITE_API_BASE_URL=http://localhost:8000

# GitHub Pages/ngrok example:
# VITE_API_BASE_URL=https://your-ngrok-domain.ngrok-free.app

# Show manual collection buttons for local development only.
VITE_SHOW_DEV_TOOLS=false
